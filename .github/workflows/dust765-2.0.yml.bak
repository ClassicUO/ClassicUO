name: Dust765

on:
  push:
    branches: [ main, developer ]
  pull_request:
    branches: [ main, developer ]
  workflow_dispatch:

jobs:
  # ──────────────────────────────────────────────────────────────
  # PR check: fast build-only, runs on every pull_request event
  # ──────────────────────────────────────────────────────────────
  build-test:
    if: github.event_name == 'pull_request'
    runs-on: windows-latest
    steps:
      - uses: actions/checkout@v4
        with:
          submodules: recursive
          fetch-depth: 0
      - name: Init submodules
        run: git submodule update --init --recursive
      - name: Override UOScript.csproj for net48
        run: Copy-Item -Path .github\UOScript.csproj -Destination external\UOSteam\UOScript\UOScript.csproj -Force
      - name: Setup .NET 8
        uses: actions/setup-dotnet@v4
        with:
          dotnet-version: '8.0.x'
      - name: Restore dependencies
        run: dotnet restore src/ClassicUO.Client/ClassicUO.Client.csproj
      - name: Build (PR check)
        run: dotnet build src/ClassicUO.Client/ClassicUO.Client.csproj -c Release --no-restore

  # ──────────────────────────────────────────────────────────────
  # Full build + artifact upload: runs only after merge (push)
  # ──────────────────────────────────────────────────────────────
  build-windows:
    if: github.event_name == 'push' || github.event_name == 'workflow_dispatch'
    runs-on: windows-latest
    steps:
      - uses: actions/checkout@v4
        with:
          submodules: recursive
          fetch-depth: 0
      - name: Init submodules
        run: git submodule update --init --recursive
      - name: Override UOScript.csproj for net48
        run: Copy-Item -Path .github\UOScript.csproj -Destination external\UOSteam\UOScript\UOScript.csproj -Force
      - name: Setup .NET 8
        uses: actions/setup-dotnet@v4
        with:
          dotnet-version: '8.0.x'
      - name: Restore dependencies
        run: dotnet restore src/ClassicUO.Client/ClassicUO.Client.csproj
      - name: Build with .NET Framework 4.8
        run: dotnet build src/ClassicUO.Client/ClassicUO.Client.csproj -c Release
        env:
          SENTRY_DSN: ${{ secrets.SENTRY_DSN }}
          SENTRY_ENV: production
      - name: Copy build artifacts
        run: |
          New-Item -ItemType Directory -Force -Path build\win-x64
          xcopy /E /I bin\Release\* build\win-x64\
      - name: Upload Artifact
        uses: actions/upload-artifact@v4
        with:
          name: Dust765-windows
          path: build/win-x64

  build-linux:
    if: github.event_name == 'push' || github.event_name == 'workflow_dispatch'
    runs-on: ubuntu-22.04
    steps:
      - uses: actions/checkout@v4
        with:
          submodules: recursive
          fetch-depth: 0
      - name: Init submodules
        run: git submodule update --init --recursive
      - name: Override UOScript.csproj for net48
        run: cp -f .github/UOScript.csproj external/UOSteam/UOScript/UOScript.csproj
      - name: Setup .NET 8
        uses: actions/setup-dotnet@v4
        with:
          dotnet-version: '8.0.x'
      - name: Install Mono
        run: |
          sudo apt-get update
          sudo apt-get install -y mono-complete
      - name: Restore dependencies
        run: dotnet restore src/ClassicUO.Client/ClassicUO.Client.csproj
      - name: Build with Mono
        run: dotnet build src/ClassicUO.Client/ClassicUO.Client.csproj -c Release
        env:
          SENTRY_DSN: ${{ secrets.SENTRY_DSN }}
          SENTRY_ENV: production
      - name: Copy build artifacts
        run: |
          mkdir -p build/linux-x64
          cp -r bin/Release/* build/linux-x64/
      - name: Upload Artifact
        uses: actions/upload-artifact@v4
        with:
          name: Dust765-linux
          path: build/linux-x64

  build-macos:
    if: github.event_name == 'push' || github.event_name == 'workflow_dispatch'
    runs-on: macos-latest
    steps:
      - uses: actions/checkout@v4
        with:
          submodules: recursive
          fetch-depth: 0
      - name: Init submodules
        run: git submodule update --init --recursive
      - name: Override UOScript.csproj for net48
        run: cp -f .github/UOScript.csproj external/UOSteam/UOScript/UOScript.csproj
      - name: Setup .NET 8
        uses: actions/setup-dotnet@v4
        with:
          dotnet-version: '8.0.x'
      - name: Install Mono
        run: brew install mono
      - name: Restore dependencies
        run: dotnet restore src/ClassicUO.Client/ClassicUO.Client.csproj
      - name: Build with Mono
        run: dotnet build src/ClassicUO.Client/ClassicUO.Client.csproj -c Release
        env:
          SENTRY_DSN: ${{ secrets.SENTRY_DSN }}
          SENTRY_ENV: production
      - name: Copy build artifacts
        run: |
          mkdir -p build/osx-x64
          cp -r bin/Release/* build/osx-x64/
      - name: Upload Artifact
        uses: actions/upload-artifact@v4
        with:
          name: Dust765-macos
          path: build/osx-x64

  # ──────────────────────────────────────────────────────────────
  # Release: auto version from git tags (semver 3.x.x)
  #   developer → v3.0.N-beta  (pre-release, published immediately)
  #   main      → v3.0.N       (stable, promotes latest beta tag)
  # ──────────────────────────────────────────────────────────────
  release:
    needs: [build-windows, build-linux, build-macos]
    if: github.event_name == 'push' || github.event_name == 'workflow_dispatch'
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Compute version tag
        id: ver
        run: |
          git fetch --tags
          IS_DEV=$([[ "${{ github.ref }}" == "refs/heads/developer" ]] && echo "true" || echo "false")

          if [ "$IS_DEV" == "true" ]; then
            # Beta branch: increment patch from latest stable tag (vX.Y.Z, no -beta)
            LATEST=$(git tag -l 'v3.*.*' | grep -Ev '\-beta' | sort -V | tail -1)
            if [ -z "$LATEST" ]; then
              NEXT="3.0.3"
            else
              IFS='.' read -r maj min pat <<< "${LATEST#v}"
              NEXT="${maj}.${min}.$((pat + 1))"
            fi
            echo "tag=v${NEXT}-beta" >> "$GITHUB_OUTPUT"
            echo "is_release=false" >> "$GITHUB_OUTPUT"
          else
            # Main branch: promote latest beta to stable
            LATEST_BETA=$(git tag -l 'v3.*.*-beta' | sort -V | tail -1)
            if [ -n "$LATEST_BETA" ]; then
              STABLE="${LATEST_BETA%-beta}"
            else
              # No beta exists yet, increment from latest stable
              LATEST=$(git tag -l 'v3.*.*' | grep -Ev '\-beta' | sort -V | tail -1)
              if [ -z "$LATEST" ]; then
                STABLE="v3.0.3"
              else
                IFS='.' read -r maj min pat <<< "${LATEST#v}"
                STABLE="v${maj}.${min}.$((pat + 1))"
              fi
            fi
            echo "tag=${STABLE}" >> "$GITHUB_OUTPUT"
            echo "is_release=true" >> "$GITHUB_OUTPUT"
          fi

      - name: Download Windows artifact
        uses: actions/download-artifact@v4
        with:
          name: Dust765-windows
          path: artifacts/windows
      - name: Download Linux artifact
        uses: actions/download-artifact@v4
        with:
          name: Dust765-linux
          path: artifacts/linux
      - name: Download macOS artifact
        uses: actions/download-artifact@v4
        with:
          name: Dust765-macos
          path: artifacts/macos
      - name: Create archives
        run: |
          TAG="${{ steps.ver.outputs.tag }}"
          zip -r Dust765-${TAG}-Windows-x64.zip artifacts/windows -x "*.DS_Store"
          cd artifacts/linux && zip -r ../../Dust765-${TAG}-linux.zip . -x "*.DS_Store" && cd ../..
          cd artifacts/macos && zip -r ../../Dust765-${TAG}-mac.zip . -x "*.DS_Store" && cd ../..
      - name: Create Release
        uses: softprops/action-gh-release@v2
        with:
          tag_name: ${{ steps.ver.outputs.tag }}
          name: ${{ steps.ver.outputs.is_release == 'true' && format('Release {0}', steps.ver.outputs.tag) || format('Beta {0}', steps.ver.outputs.tag) }}
          draft: false
          prerelease: ${{ steps.ver.outputs.is_release != 'true' }}
          make_latest: ${{ steps.ver.outputs.is_release == 'true' }}
          files: |
            Dust765-${{ steps.ver.outputs.tag }}-Windows-x64.zip
            Dust765-${{ steps.ver.outputs.tag }}-linux.zip
            Dust765-${{ steps.ver.outputs.tag }}-mac.zip
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
    if: github.event_name == 'pull_request'
    runs-on: windows-latest
    steps:
      - uses: actions/checkout@v4
        with:
          submodules: recursive
          fetch-depth: 0
      - name: Init submodules
        run: git submodule update --init --recursive
      - name: Override UOScript.csproj for net48
        run: Copy-Item -Path .github\UOScript.csproj -Destination external\UOSteam\UOScript\UOScript.csproj -Force
      - name: Setup .NET 8
        uses: actions/setup-dotnet@v4
        with:
          dotnet-version: '8.0.x'
      - name: Restore dependencies
        run: dotnet restore src/ClassicUO.Client/ClassicUO.Client.csproj
      - name: Build (PR check)
        run: dotnet build src/ClassicUO.Client/ClassicUO.Client.csproj -c Release --no-restore

  # ──────────────────────────────────────────────────────────────
  # Full build + artifact upload: runs only after merge (push)
  # ──────────────────────────────────────────────────────────────
  build-windows:
    if: github.event_name == 'push' || github.event_name == 'workflow_dispatch'
    runs-on: windows-latest
    steps:
      - uses: actions/checkout@v4
        with:
          submodules: recursive
          fetch-depth: 0
      - name: Init submodules
        run: git submodule update --init --recursive
      - name: Override UOScript.csproj for net48
        run: Copy-Item -Path .github\UOScript.csproj -Destination external\UOSteam\UOScript\UOScript.csproj -Force
      - name: Setup .NET 8
        uses: actions/setup-dotnet@v4
        with:
          dotnet-version: '8.0.x'
      - name: Restore dependencies
        run: dotnet restore src/ClassicUO.Client/ClassicUO.Client.csproj
      - name: Build with .NET Framework 4.8
        run: dotnet build src/ClassicUO.Client/ClassicUO.Client.csproj -c Release
        env:
          SENTRY_DSN: ${{ secrets.SENTRY_DSN }}
          SENTRY_ENV: production
      - name: Copy build artifacts
        run: |
          New-Item -ItemType Directory -Force -Path build\win-x64
          xcopy /E /I bin\Release\* build\win-x64\
      - name: Upload Artifact
        uses: actions/upload-artifact@v4
        with:
          name: Dust765-windows
          path: build/win-x64

  build-linux:
    if: github.event_name == 'push' || github.event_name == 'workflow_dispatch'
    runs-on: ubuntu-22.04
    steps:
      - uses: actions/checkout@v4
        with:
          submodules: recursive
          fetch-depth: 0
      - name: Init submodules
        run: git submodule update --init --recursive
      - name: Override UOScript.csproj for net48
        run: cp -f .github/UOScript.csproj external/UOSteam/UOScript/UOScript.csproj
      - name: Setup .NET 8
        uses: actions/setup-dotnet@v4
        with:
          dotnet-version: '8.0.x'
      - name: Install Mono
        run: |
          sudo apt-get update
          sudo apt-get install -y mono-complete
      - name: Restore dependencies
        run: dotnet restore src/ClassicUO.Client/ClassicUO.Client.csproj
      - name: Build with Mono
        run: dotnet build src/ClassicUO.Client/ClassicUO.Client.csproj -c Release
        env:
          SENTRY_DSN: ${{ secrets.SENTRY_DSN }}
          SENTRY_ENV: production
      - name: Copy build artifacts
        run: |
          mkdir -p build/linux-x64
          cp -r bin/Release/* build/linux-x64/
      - name: Upload Artifact
        uses: actions/upload-artifact@v4
        with:
          name: Dust765-linux
          path: build/linux-x64

  build-macos:
    if: github.event_name == 'push' || github.event_name == 'workflow_dispatch'
    runs-on: macos-latest
    steps:
      - uses: actions/checkout@v4
        with:
          submodules: recursive
          fetch-depth: 0
      - name: Init submodules
        run: git submodule update --init --recursive
      - name: Override UOScript.csproj for net48
        run: cp -f .github/UOScript.csproj external/UOSteam/UOScript/UOScript.csproj
      - name: Setup .NET 8
        uses: actions/setup-dotnet@v4
        with:
          dotnet-version: '8.0.x'
      - name: Install Mono
        run: brew install mono
      - name: Restore dependencies
        run: dotnet restore src/ClassicUO.Client/ClassicUO.Client.csproj
      - name: Build with Mono
        run: dotnet build src/ClassicUO.Client/ClassicUO.Client.csproj -c Release
        env:
          SENTRY_DSN: ${{ secrets.SENTRY_DSN }}
          SENTRY_ENV: production
      - name: Copy build artifacts
        run: |
          mkdir -p build/osx-x64
          cp -r bin/Release/* build/osx-x64/
      - name: Upload Artifact
        uses: actions/upload-artifact@v4
        with:
          name: Dust765-macos
          path: build/osx-x64

  release:
    needs: [build-windows, build-linux, build-macos]
    if: |
      (github.event_name == 'push' && github.ref == 'refs/heads/developer') ||
      github.event_name == 'workflow_dispatch'
    runs-on: ubuntu-latest
    env:
      TAG: ${{ github.event_name == 'workflow_dispatch' && format('v{0}', github.event.inputs.version) || format('v{0}-beta', github.run_number) }}
      IS_RELEASE: ${{ github.event_name == 'workflow_dispatch' }}
    steps:
      - name: Download Windows artifact
        uses: actions/download-artifact@v4
        with:
          name: Dust765-windows
          path: artifacts/windows
      - name: Download Linux artifact
        uses: actions/download-artifact@v4
        with:
          name: Dust765-linux
          path: artifacts/linux
      - name: Download macOS artifact
        uses: actions/download-artifact@v4
        with:
          name: Dust765-macos
          path: artifacts/macos
      - name: Create Windows archive
        run: zip -r Dust765-${{ env.TAG }}-Windows-x64.zip artifacts/windows -x "*.DS_Store"
      - name: Create Linux archive
        run: cd artifacts/linux && zip -r ../../Dust765-${{ env.TAG }}-linux.zip . -x "*.DS_Store" && cd ../..
      - name: Create macOS archive
        run: cd artifacts/macos && zip -r ../../Dust765-${{ env.TAG }}-mac.zip . -x "*.DS_Store" && cd ../..
      - name: Create Release
        uses: softprops/action-gh-release@v2
        with:
          tag_name: ${{ env.TAG }}
          name: ${{ env.IS_RELEASE == 'true' && format('Release {0}', env.TAG) || format('Beta {0}', env.TAG) }}
          draft: ${{ env.IS_RELEASE == 'true' && 'true' || 'false' }}
          prerelease: ${{ env.IS_RELEASE != 'true' && 'true' || 'false' }}
          make_latest: ${{ env.IS_RELEASE == 'true' && 'true' || 'false' }}
          files: |
            Dust765-${{ env.TAG }}-Windows-x64.zip
            Dust765-${{ env.TAG }}-linux.zip
            Dust765-${{ env.TAG }}-mac.zip
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
